# PhantomProbe Environment Configuration

# Dashboard Configuration
PHANTOMPROBE_DASHBOARD_HOST=127.0.0.1
PHANTOMPROBE_DASHBOARD_PORT=8080

# Burp Suite Integration
BURP_API_URL=http://127.0.0.1:1337
BURP_API_KEY=your-burp-api-key-here

# Playwright Configuration
PLAYWRIGHT_BROWSERS_PATH=0
# Set to 0 to use system Chromium instead of bundled browsers

# CVE API (NVD API)
NVD_API_KEY=your-nvd-api-key-here
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
